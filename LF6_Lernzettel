<body>

<div class="page-header">
  <div class="badge">LF6 · Fachinformatiker Systemintegration</div>
  <h1>SLA & Standards<br>bei IT-Dienstleistungen</h1>
  <p>Lernzettel auf Basis der Unterrichtsblätter · Mit interaktiven Testfragen</p>
</div>

<nav id="nav">
  <button class="active" onclick="showTab('sla-grundlagen')">SLA Grundlagen</button>
  <button onclick="showTab('sla-kpis')">KPIs im SLA</button>
  <button onclick="showTab('service-levels')">Service Levels</button>
  <button onclick="showTab('standards')">IT-Standards</button>
