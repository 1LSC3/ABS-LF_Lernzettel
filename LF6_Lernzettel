let scores = new Array(questions.length).fill(null);

function buildQuiz() {
  const container = document.getElementById('quiz-container');
  questions.forEach((q, qi) => {
    const div = document.createElement('div');
    div.className = 'q-card';
    div.innerHTML = `
      <div class="q-num">FRAGE ${qi + 1} VON ${questions.length}</div>
      <div class="q-text">${q.q}</div>
      <div class="q-opts" id="opts-${qi}">
        ${q.opts.map((o, oi) => `
          <button class="q-opt" onclick="answer(${qi}, ${oi})" id="opt-${qi}-${oi}">
            <span class="ol">${String.fromCharCode(65 + oi)}</span>
            <span>${o}</span>
          </button>`).join('')}
      </div>
      <div class="q-explain" id="exp-${qi}"><strong>Erklärung:</strong> ${q.explain}</div>
    `;
    container.appendChild(div);
  });
}

function answer(qi, oi) {
  const opts = document.querySelectorAll(`#opts-${qi} .q-opt`);
  if ([...opts].some(o => o.disabled)) return;
  opts.forEach((o, i) => {
    o.disabled = true;
    if (i === questions[qi].correct) o.classList.add('correct');
    else if (i === oi && oi !== questions[qi].correct) o.classList.add('wrong');
  });
  if (scores[qi] === null) {
    scores[qi] = oi === questions[qi].correct ? 1 : 0;
    const right = scores.filter(v => v === 1).length;
    const answered = scores.filter(v => v !== null).length;
    document.getElementById('score-display').textContent = `${right} / ${questions.length}`;
  }
  document.getElementById(`exp-${qi}`).classList.add('show');
}

buildQuiz();
