  renderQuiz('q-sel',  QUIZ.sel,  's-sel');
  renderQuiz('q-agg',  QUIZ.agg,  's-agg');
  renderQuiz('q-join', QUIZ.join, 's-join');
  // Kompetenzcheck
  renderQuiz('q-kc1',  KC1, 's-kc1');
  renderQuiz('q-kc2',  KC2, 's-kc2');
});
