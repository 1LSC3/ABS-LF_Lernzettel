// ════════════════════════════════════════════════════════
// RENDER ENGINE
// ════════════════════════════════════════════════════════

function renderQuiz(containerId, data, scoreId) {
  const container = document.getElementById(containerId);
  if (!container) return;
  container.innerHTML = '';

  data.forEach((item, qi) => {
    const qDiv = document.createElement('div');
    qDiv.className = 'quiz-q';
    qDiv.id = `${containerId}-${qi}`;

    // Num
    const num = document.createElement('div');
    num.className = 'qnum';
    num.textContent = `Frage ${qi + 1} / ${data.length}`;
    qDiv.appendChild(num);

    // Question text
    const qtext = document.createElement('div');
    qtext.className = 'qtext';
    qtext.innerHTML = escQ(item.q);
    qDiv.appendChild(qtext);

    // Buttons row
    const row = document.createElement('div');
    row.className = 'ans-row';
    item.opts.forEach((opt, oi) => {
      const btn = document.createElement('button');
      btn.className = 'ans-btn';
      btn.innerHTML = escQ(opt);
      btn.addEventListener('click', () => handleAns(containerId, scoreId, data, qi, oi));
      row.appendChild(btn);
    });
    qDiv.appendChild(row);

    // Feedback
    const fb = document.createElement('div');
    fb.className = 'quiz-fb';
    qDiv.appendChild(fb);

    // Reset button
    const rb = document.createElement('button');
    rb.className = 'reset-btn';
    rb.textContent = '↩ Antwort ändern';
    rb.addEventListener('click', () => resetAns(containerId, scoreId, data, qi));
    qDiv.appendChild(rb);

    container.appendChild(qDiv);
  });
}

function escQ(s) {
  return s.replace(/`([^`]+)`/g, '<code>$1</code>');
}

function handleAns(cid, sid, data, qi, oi) {
  const item = data[qi];
  const qDiv = document.getElementById(`${cid}-${qi}`);
  if (!qDiv) return;

  const btns = qDiv.querySelectorAll('.ans-btn');
  const fb = qDiv.querySelector('.quiz-fb');
  const rb = qDiv.querySelector('.reset-btn');

  const correct = (oi === item.c);

  // Lock all buttons
  btns.forEach((b, bi) => {
    b.className = 'ans-btn';
    if (bi === oi && correct) b.classList.add('sel-correct');
    else if (bi === oi && !correct) b.classList.add('sel-wrong');
    else if (bi === item.c && !correct) b.classList.add('hint-correct');
    else b.classList.add('locked');
    // prevent re-click by removing event – will be re-added on reset
    b.replaceWith(b.cloneNode(true));
  });

  fb.className = 'quiz-fb ' + (correct ? 'show-ok' : 'show-fail');
  fb.textContent = (correct ? '✅ ' : '❌ ') + item.e;
  rb.style.display = 'inline-block';

  qDiv.className = 'quiz-q ' + (correct ? 'answered-correct' : 'answered-wrong');

  updateScore(cid, sid, data);
}

function resetAns(cid, sid, data, qi) {
  const item = data[qi];
  const qDiv = document.getElementById(`${cid}-${qi}`);
  if (!qDiv) return;

  // Re-build buttons with fresh listeners
  const row = qDiv.querySelector('.ans-row');
  row.innerHTML = '';
  item.opts.forEach((opt, oi) => {
    const btn = document.createElement('button');
    btn.className = 'ans-btn';
    btn.innerHTML = escQ(opt);
    btn.addEventListener('click', () => handleAns(cid, sid, data, qi, oi));
    row.appendChild(btn);
  });

  const fb = qDiv.querySelector('.quiz-fb');
  fb.className = 'quiz-fb';
  fb.textContent = '';

  const rb = qDiv.querySelector('.reset-btn');
  rb.style.display = 'none';

  qDiv.className = 'quiz-q';
  updateScore(cid, sid, data);
}

function updateScore(cid, sid, data) {
  const scoreEl = document.getElementById(sid);
  if (!scoreEl) return;
  let answered = 0, correct = 0;
  data.forEach((_, qi) => {
    const qDiv = document.getElementById(`${cid}-${qi}`);
    if (!qDiv) return;
    if (qDiv.classList.contains('answered-correct')) { answered++; correct++; }
    else if (qDiv.classList.contains('answered-wrong')) { answered++; }
  });
  if (answered === 0) { scoreEl.className = 'quiz-score'; return; }
  const pct = Math.round(correct / data.length * 100);
  const col = pct >= 80 ? 'var(--green)' : pct >= 50 ? 'var(--amber)' : 'var(--red)';
  scoreEl.className = 'quiz-score show';
  scoreEl.innerHTML = `<span style="color:${col};font-weight:600">${correct} / ${data.length} richtig (${pct}%)</span> &nbsp;·&nbsp; ${data.length - answered} noch offen`;
}

// ════════════════════════════════════════════════════════
// TAB NAVIGATION
// ════════════════════════════════════════════════════════

const TAB_IDS = ['gui','cli','sqlg','er','sel','agg','join','kcheck'];

function show(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  const sec = document.getElementById(id);
  if (sec) sec.classList.add('active');
  const idx = TAB_IDS.indexOf(id);
  const tabs = document.querySelectorAll('.tab');
  if (idx >= 0 && tabs[idx]) tabs[idx].classList.add('active');
  window.scrollTo(0, 0);
}

