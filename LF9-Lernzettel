<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LF9 Lernzettel – Netzwerke und Dienste bereitstellen</title>
<style>
  :root {
    --bg: #0f1117;
    --bg2: #181c25;
    --bg3: #1e2330;
    --border: rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.14);
    --text: #e8eaf0;
    --text2: #9aa0b4;
    --text3: #5c6378;
    --blue: #4f8ef7;
    --blue-bg: rgba(79,142,247,0.12);
    --teal: #2dd4bf;
    --teal-bg: rgba(45,212,191,0.10);
    --amber: #f59e0b;
    --amber-bg: rgba(245,158,11,0.10);
    --red: #f87171;
    --red-bg: rgba(248,113,113,0.10);
    --green: #4ade80;
    --green-bg: rgba(74,222,128,0.10);
    --purple: #a78bfa;
    --purple-bg: rgba(167,139,250,0.10);
    --radius: 10px;
    --radius-sm: 6px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    font-size: 15px;
  }

  /* ---- LAYOUT ---- */
  .wrapper { display: flex; min-height: 100vh; }
  
  nav {
    width: 240px;
    min-width: 240px;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    padding: 1.5rem 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }
  nav .logo {
    padding: 0 1.25rem 1.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  nav .logo h1 { font-size: 14px; font-weight: 700; color: var(--blue); letter-spacing: 0.05em; text-transform: uppercase; }
  nav .logo p { font-size: 11px; color: var(--text3); margin-top: 2px; }
  nav a {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 1.25rem; font-size: 13px; color: var(--text2);
    text-decoration: none; border-left: 2px solid transparent;
    transition: all 0.15s;
  }
  nav a:hover { color: var(--text); background: rgba(255,255,255,0.04); }
  nav a.active { color: var(--blue); border-left-color: var(--blue); background: var(--blue-bg); }
  nav .nav-section { font-size: 10px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; padding: 1rem 1.25rem 0.35rem; }
  nav .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  
  main { flex: 1; padding: 2.5rem 2rem; max-width: 900px; }

  /* ---- TYPOGRAPHY ---- */
  .page-title { font-size: 28px; font-weight: 700; color: var(--text); margin-bottom: 0.25rem; }
  .page-sub { font-size: 14px; color: var(--text2); margin-bottom: 0.5rem; }
  .chapter-header {
    display: flex; align-items: center; gap: 12px;
    margin: 2.5rem 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .chapter-icon {
    width: 36px; height: 36px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .chapter-header h2 { font-size: 20px; font-weight: 600; }
  .badge {
    font-size: 10px; font-weight: 600; padding: 3px 9px; border-radius: 20px;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  h3.sec { font-size: 16px; font-weight: 600; color: var(--text); margin: 1.5rem 0 0.75rem; display: flex; align-items: center; gap: 8px; }
  h3.sec::before { content: ''; display: block; width: 3px; height: 16px; border-radius: 2px; background: var(--blue); flex-shrink: 0; }
  p { color: var(--text2); font-size: 14px; margin-bottom: 0.5rem; }

  /* ---- CARDS ---- */
  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .card.blue { border-left: 3px solid var(--blue); }
  .card.teal { border-left: 3px solid var(--teal); }
  .card.amber { border-left: 3px solid var(--amber); }
  .card.red { border-left: 3px solid var(--red); }
  .card.green { border-left: 3px solid var(--green); }
  .card.purple { border-left: 3px solid var(--purple); }

  /* ---- DEF TABLE ---- */
  .def-table { width: 100%; border-collapse: collapse; }
  .def-table tr { border-bottom: 1px solid var(--border); }
  .def-table tr:last-child { border-bottom: none; }
  .def-table td { padding: 9px 0; vertical-align: top; font-size: 13.5px; }
  .def-table td:first-child { width: 160px; font-weight: 600; color: var(--text); padding-right: 1rem; }
  .def-table td:last-child { color: var(--text2); }
  .def-table .sub { font-size: 11px; color: var(--text3); font-weight: 400; display: block; margin-top: 2px; }

  /* ---- TAGS ---- */
  .tag { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px; margin: 2px 3px 2px 0; }
  .tag.blue { background: var(--blue-bg); color: var(--blue); }
  .tag.teal { background: var(--teal-bg); color: var(--teal); }
  .tag.amber { background: var(--amber-bg); color: var(--amber); }
  .tag.red { background: var(--red-bg); color: var(--red); }
  .tag.green { background: var(--green-bg); color: var(--green); }
  .tag.purple { background: var(--purple-bg); color: var(--purple); }

  /* ---- FLOW DIAGRAM ---- */
  .flow { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; margin: 0.75rem 0; }
  .flow-step { background: var(--bg3); border: 1px solid var(--border2); border-radius: 6px; padding: 6px 12px; font-size: 12.5px; color: var(--text); }
  .flow-step small { display: block; font-size: 10px; color: var(--text3); margin-top: 1px; }
  .flow-arrow { color: var(--text3); font-size: 14px; }

  /* ---- COMPARISON GRID ---- */
  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 0.75rem 0 1rem; }
  .compare-card { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1rem; }
  .compare-card h4 { font-size: 13px; font-weight: 600; margin-bottom: 0.5rem; }
  .compare-card ul { list-style: none; padding: 0; }
  .compare-card li { font-size: 12.5px; color: var(--text2); padding: 3px 0; padding-left: 14px; position: relative; }
  .compare-card li::before { content: '→'; position: absolute; left: 0; color: var(--text3); }

  /* ---- INFO BOXES ---- */
  .info-box { border-radius: var(--radius-sm); padding: 0.75rem 1rem; margin: 0.75rem 0; font-size: 13px; }
  .info-box.blue { background: var(--blue-bg); border: 1px solid rgba(79,142,247,0.2); color: #93b8fb; }
  .info-box.amber { background: var(--amber-bg); border: 1px solid rgba(245,158,11,0.2); color: #fcd264; }
  .info-box.green { background: var(--green-bg); border: 1px solid rgba(74,222,128,0.2); color: #86efac; }
  .info-box.red { background: var(--red-bg); border: 1px solid rgba(248,113,113,0.2); color: #fca5a5; }
  .info-box strong { font-weight: 600; }

  /* ---- TOM GRID ---- */
  .tom-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 8px; margin: 0.75rem 0; }
  .tom-item { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; }
  .tom-num { font-size: 10px; font-weight: 700; color: var(--text3); margin-bottom: 4px; }
  .tom-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
  .tom-desc { font-size: 11.5px; color: var(--text2); line-height: 1.5; }

  /* ---- QUIZ ---- */
  .quiz-section { margin-top: 2rem; }
  .quiz-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .quiz-header h3 { font-size: 15px; font-weight: 600; color: var(--text); }
  .quiz-progress-text { font-size: 12px; color: var(--text3); }
  .quiz-block { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 0.75rem; }
  .quiz-q { font-size: 14px; font-weight: 500; color: var(--text); margin-bottom: 0.75rem; line-height: 1.5; }
  .quiz-num { font-size: 11px; color: var(--text3); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
  .quiz-opts { display: flex; flex-direction: column; gap: 7px; }
  .quiz-opt {
    background: var(--bg3); border: 1px solid var(--border2); border-radius: var(--radius-sm);
    padding: 9px 14px; font-size: 13px; color: var(--text); cursor: pointer;
    text-align: left; transition: border-color 0.15s, background 0.15s; line-height: 1.5;
  }
  .quiz-opt:hover:not(:disabled) { border-color: var(--blue); background: var(--blue-bg); }
  .quiz-opt.correct { border-color: var(--green) !important; background: var(--green-bg) !important; color: #86efac !important; }
  .quiz-opt.wrong { border-color: var(--red) !important; background: var(--red-bg) !important; color: #fca5a5 !important; }
  .quiz-opt.show-correct { border-color: var(--green); background: var(--green-bg); color: #86efac; opacity: 0.6; }
  .quiz-opt:disabled { cursor: default; }
  .quiz-opt.selected { border-color: var(--blue); background: var(--blue-bg); color: var(--blue); }
  .submit-btn {
    display: none; margin-top: 10px; padding: 8px 20px;
    background: var(--blue); color: #fff; border: none; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 600; cursor: pointer;
  }
  .submit-btn:hover { opacity: 0.88; }
  .tf-row { display: flex; gap: 10px; margin-top: 0.5rem; }
  .tf-btn {
    flex: 1; padding: 9px; border: 1px solid var(--border2); border-radius: var(--radius-sm);
    font-size: 13px; cursor: pointer; background: var(--bg3); color: var(--text);
    font-weight: 500; transition: all 0.15s;
  }
  .tf-btn:hover:not(:disabled) { border-color: var(--blue); background: var(--blue-bg); }
  .tf-btn.correct { border-color: var(--green) !important; background: var(--green-bg) !important; color: #86efac !important; }
  .tf-btn.wrong { border-color: var(--red) !important; background: var(--red-bg) !important; color: #fca5a5 !important; }
  .tf-btn:disabled { cursor: default; }
  .feedback {
    margin-top: 0.6rem; font-size: 12.5px; padding: 7px 12px;
    border-radius: var(--radius-sm); display: none;
  }
  .feedback.show { display: block; }
  .feedback.ok { background: var(--green-bg); color: #86efac; border: 1px solid rgba(74,222,128,0.2); }
  .feedback.nok { background: var(--red-bg); color: #fca5a5; border: 1px solid rgba(248,113,113,0.2); }
  .reset-btn {
    margin-top: 8px; font-size: 11.5px; color: var(--text3);
    cursor: pointer; background: none; border: none; padding: 0; text-decoration: underline;
  }
  .reset-btn:hover { color: var(--text2); }

  /* ---- PROGRESS BAR ---- */
  .global-progress { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 2rem; }
  .gp-label { font-size: 12px; color: var(--text2); margin-bottom: 0.5rem; display: flex; justify-content: space-between; }
  .gp-bar { height: 6px; background: var(--bg3); border-radius: 3px; overflow: hidden; }
  .gp-fill { height: 6px; background: linear-gradient(90deg, var(--blue), var(--teal)); border-radius: 3px; width: 0%; transition: width 0.4s; }

  /* ---- HIGHLIGHT LIST ---- */
  ul.hl { list-style: none; padding: 0; }
  ul.hl li { font-size: 13.5px; color: var(--text2); padding: 5px 0 5px 20px; position: relative; border-bottom: 1px solid var(--border); }
  ul.hl li:last-child { border-bottom: none; }
  ul.hl li::before { content: '▸'; position: absolute; left: 0; color: var(--blue); font-size: 11px; top: 7px; }
  ul.hl li strong { color: var(--text); font-weight: 600; }

  /* ---- PROTOCOL TABLE ---- */
  .proto-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .proto-table th { text-align: left; padding: 8px 10px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text3); border-bottom: 1px solid var(--border2); }
  .proto-table td { padding: 9px 10px; border-bottom: 1px solid var(--border); color: var(--text2); vertical-align: top; }
  .proto-table tr:last-child td { border-bottom: none; }
  .proto-table td:first-child { font-weight: 600; color: var(--text); }

  /* ---- SCROLLBAR ---- */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 3px; }

  @media (max-width: 768px) {
    nav { display: none; }
    main { padding: 1.5rem 1rem; }
    .compare-grid { grid-template-columns: 1fr; }
    .tom-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
