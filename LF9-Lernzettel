  <p style="font-size:12px;color:#5c6378;text-align:center;margin-top:3rem;padding-bottom:2rem">LF9 Lernzettel · August-Bebel-Schule · 2024/25</p>
</main>
</div>

<script>
// ── Quiz State ──────────────────────────────────────────────
const TOTAL = 25;
const state = {}; // qid -> { selected: index, submitted: bool }
const answered = new Set();

// correct answer index (0-based) per question
const correctIndex = {
  q01:1, q02:2, q03:'r', q04:1, q05:'f',
  q06:2, q07:1, q08:'r',
  q09:2, q10:'f', q11:1, q12:2, q13:'r', q14:1, q15:'f',
  q16:2, q17:'f', q18:1, q19:'r', q20:2,
  q21:2, q22:'f', q23:1, q24:0, q25:'r'
};

const sectionMap = {
  'q1-prog': ['q01','q02','q03','q04','q05','q06','q07','q08'],
  'q2-prog': ['q09','q10','q11','q12','q13','q14','q15'],
  'q3-prog': ['q16','q17','q18','q19','q20','q21','q22','q23','q24','q25']
};

function updateProgress() {
  document.getElementById('gp-text').textContent = answered.size + ' / ' + TOTAL + ' beantwortet';
  document.getElementById('gp-fill').style.width = Math.round(answered.size / TOTAL * 100) + '%';
  for (const [id, qs] of Object.entries(sectionMap)) {
    const done = qs.filter(q => answered.has(q)).length;
    document.getElementById(id).textContent = done + '/' + qs.length + ' beantwortet';
  }
}

// ── MC: select (no lock-in until submitted) ──────────────────
function mc(qid, btn, idx) {
  const s = state[qid] || (state[qid] = {});
  if (s.submitted) return; // locked after submit
  s.selected = idx;

  const container = document.getElementById(qid);
  container.querySelectorAll('button.quiz-opt').forEach((b, i) => {
    b.classList.toggle('selected', i === idx);
  });

  // show submit button
  const submitBtn = document.getElementById(qid + '-submit');
  if (submitBtn) submitBtn.style.display = 'inline-block';
}

function submitMC(qid) {
  const s = state[qid];
  if (!s || s.selected === undefined) return;
  s.submitted = true;

  const container = document.getElementById(qid);
  const correct = correctIndex[qid];
  const fb = document.getElementById(qid + '-fb');
  const submitBtn = document.getElementById(qid + '-submit');
  if (submitBtn) submitBtn.style.display = 'none';

  container.querySelectorAll('button.quiz-opt').forEach((b, i) => {
    b.classList.remove('selected');
    if (i === correct) b.classList.add('correct');
    else if (i === s.selected && s.selected !== correct) b.classList.add('wrong');
  });

  if (s.selected === correct) {
    fb.textContent = '✓ Richtig!';
    fb.className = 'feedback show ok';
  } else {
    fb.textContent = '✗ Leider falsch. Die korrekte Antwort ist grün markiert.';
    fb.className = 'feedback show nok';
  }
  answered.add(qid);
  updateProgress();
}

// ── TF: select & auto-submit ──────────────────────────────────
function tf(qid, btn, isCorrect) {
  const s = state[qid] || (state[qid] = {});
  if (s.submitted) return;
  s.submitted = true;
  s.correct = isCorrect;

  const container = document.getElementById(qid);
  const fb = document.getElementById(qid + '-fb');
  const btns = container.querySelectorAll('button.tf-btn');

  // mark correct button green, wrong button red
  btns.forEach(b => {
    const bCorrect = b.getAttribute('data-correct') === 'true';
    if (bCorrect) b.classList.add('correct');
    else if (b === btn && !isCorrect) b.classList.add('wrong');
  });

  if (isCorrect) {
    fb.textContent = '✓ Richtig!';
    fb.className = 'feedback show ok';
  } else {
    fb.textContent = '✗ Falsch. Die richtige Antwort ist grün markiert.';
    fb.className = 'feedback show nok';
  }
  answered.add(qid);
  updateProgress();
}

// ── Reset ─────────────────────────────────────────────────────
function resetQ(qid, type) {
  delete state[qid];
  answered.delete(qid);

  const container = document.getElementById(qid);
  if (type === 'mc') {
    container.querySelectorAll('button.quiz-opt').forEach(b => {
      b.className = 'quiz-opt';
    });
    const submitBtn = document.getElementById(qid + '-submit');
    if (submitBtn) submitBtn.style.display = 'none';
  } else {
    container.querySelectorAll('button.tf-btn').forEach(b => {
      b.className = 'tf-btn';
    });
  }
  const fb = document.getElementById(qid + '-fb');
  fb.className = 'feedback';
  updateProgress();
}

// Nav active on scroll
window.addEventListener('scroll', () => {
  let current = '';
  document.querySelectorAll('section[id]').forEach(sec => {
    if (window.scrollY >= sec.offsetTop - 120) current = sec.id;
  });
  document.querySelectorAll('nav a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
});

updateProgress();
</script>
</body>
</html>
