<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LF7 – Cyberphysische Systeme | Lernzettel</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0e0f14; --surface:#161820; --card:#1c1e27; --border:#2a2d3a;
  --accent:#7c6aff; --accent2:#ff6a8a; --accent3:#3de8b0; --accent4:#ffb347;
  --text:#e8eaf0; --muted:#7b7f96; --code-bg:#11121a;
  --correct:#3de8b0; --wrong:#ff6a8a;
  --mono:'JetBrains Mono',monospace; --sans:'Syne',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;overflow-x:hidden;}

/* NAV */
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 16px;display:flex;align-items:stretch;overflow-x:auto;scrollbar-width:none;position:sticky;top:0;z-index:200;}
.topbar::-webkit-scrollbar{display:none;}
.tab{padding:14px 16px;border:none;background:transparent;color:var(--muted);font-family:var(--mono);font-size:12px;cursor:pointer;white-space:nowrap;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;display:flex;align-items:center;gap:6px;}
.tab:hover{color:var(--text);}
.tab.active{color:white;border-bottom-color:var(--accent);}

/* PAGES */
.page{display:none;}
.page.active{display:block;animation:fadeUp .25s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* HERO */
.page-hero{padding:36px 36px 28px;border-bottom:1px solid var(--border);position:relative;overflow:hidden;}
.page-hero::after{content:'';position:absolute;top:-60px;right:-60px;width:280px;height:280px;background:radial-gradient(circle,var(--glow,rgba(124,106,255,.15)) 0%,transparent 70%);pointer-events:none;}
.hero-label{font-family:var(--mono);font-size:10px;letter-spacing:3px;color:var(--accent);text-transform:uppercase;margin-bottom:8px;}
.hero-title{font-size:clamp(22px,4vw,38px);font-weight:800;line-height:1.1;}
.hero-title span{color:var(--accent);}
.hero-sub{color:var(--muted);font-size:12px;font-family:var(--mono);margin-top:7px;}

/* HOME */
.home-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;padding:28px;}
.home-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:22px;cursor:pointer;transition:transform .15s,border-color .15s;}
.home-card:hover{transform:translateY(-2px);border-color:var(--accent);}
.hc-icon{font-size:26px;margin-bottom:10px;}
.hc-title{font-size:16px;font-weight:700;margin-bottom:5px;}
.hc-desc{font-size:11px;color:var(--muted);line-height:1.6;font-family:var(--mono);}
.hc-score{margin-top:12px;font-family:var(--mono);font-size:11px;color:var(--accent3);}

/* CONTENT */
.content{max-width:900px;margin:0 auto;padding:28px 22px 80px;}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:14px;}
.card h3{font-size:13px;font-weight:700;margin-bottom:11px;color:var(--accent3);text-transform:uppercase;letter-spacing:.5px;}
.card p,.card li{font-size:13px;line-height:1.8;color:#c5c8d8;}
.card ul,.card ol{padding-left:18px;}
.card li{margin-bottom:5px;}

/* 2-COL GRID */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
@media(max-width:600px){.two-col,.three-col{grid-template-columns:1fr;}}

/* DEF CARD */
.def-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;}
.def-card .tag{font-family:var(--mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;padding:3px 8px;border-radius:4px;margin-bottom:9px;display:inline-block;}
.def-card p{font-size:12px;line-height:1.65;color:#b0b4cc;}
.def-card h4{font-size:13px;font-weight:700;margin-bottom:7px;}

/* TABLE */
.styled-table{width:100%;border-collapse:collapse;font-size:13px;border-radius:10px;overflow:hidden;}
.styled-table th{background:var(--accent);color:white;padding:10px 14px;text-align:left;font-size:11px;letter-spacing:.5px;}
.styled-table td{padding:10px 14px;border-bottom:1px solid var(--border);background:var(--card);color:#c5c8d8;vertical-align:top;font-size:13px;}
.styled-table tr:last-child td{border-bottom:none;}
.styled-table code{font-family:var(--mono);background:var(--code-bg);padding:2px 6px;border-radius:4px;font-size:11px;color:var(--accent3);}

/* CODE */
.code-block{background:var(--code-bg);border:1px solid var(--border);border-radius:10px;padding:16px;font-family:var(--mono);font-size:12px;line-height:1.9;overflow-x:auto;}
.cl{display:flex;gap:12px;}
.ln{color:var(--muted);min-width:20px;user-select:none;}
.kw{color:#7c6aff;} .fn{color:#ffb347;} .str{color:var(--accent3);} .cm{color:#555d7a;font-style:italic;} .num{color:var(--accent2);}

/* HIGHLIGHT BOXES */
.hb{border-radius:10px;padding:13px 17px;margin:11px 0;font-size:13px;line-height:1.7;}
.hb-purple{background:rgba(124,106,255,.08);border-left:3px solid var(--accent);}
.hb-green{background:rgba(61,232,176,.08);border-left:3px solid var(--accent3);}
.hb-orange{background:rgba(255,179,71,.08);border-left:3px solid var(--accent4);}
.hb-pink{background:rgba(255,106,138,.08);border-left:3px solid var(--accent2);}
.hb strong{color:var(--text);}

/* STEPS */
.steps{display:flex;flex-direction:column;gap:8px;}
.step{display:flex;gap:14px;align-items:flex-start;}
.step-num{background:var(--accent);color:white;border-radius:50%;width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;flex-shrink:0;margin-top:2px;}
.step-body{font-size:13px;line-height:1.7;color:#c5c8d8;}
.step-body strong{color:var(--text);}

/* DEVOPS */
.devops-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:12px 0;}
@media(max-width:540px){.devops-grid{grid-template-columns:repeat(2,1fr);}}
.dp{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:11px;text-align:center;}
.dp .dn{font-family:var(--mono);font-size:9px;color:var(--muted);margin-bottom:3px;}
.dp .dt{font-weight:700;font-size:14px;}
.dp .de{color:var(--muted);font-size:10px;margin-top:2px;}
.dp.dev{border-top:2px solid var(--accent);}
.dp.ops{border-top:2px solid var(--accent3);}

/* RPZ */
.rpz-box{background:var(--card);border-radius:10px;padding:20px;text-align:center;font-family:var(--mono);}
.rpz-formula{font-size:22px;color:var(--accent4);margin:8px 0;font-weight:700;}
.rpz-legend{display:flex;justify-content:center;gap:16px;font-size:11px;color:var(--muted);margin-top:10px;flex-wrap:wrap;}

/* QUIZ */
.quiz-block{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:22px;margin-top:26px;}
.quiz-label{font-family:var(--mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--accent2);margin-bottom:18px;display:flex;align-items:center;gap:7px;}
.quiz-label::before{content:'◆';font-size:7px;}
.q-item{margin-bottom:26px;padding-bottom:26px;border-bottom:1px solid var(--border);}
.q-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.q-num{font-family:var(--mono);font-size:10px;color:var(--accent);margin-bottom:4px;letter-spacing:1px;}
.q-text{font-size:14px;font-weight:600;margin-bottom:12px;line-height:1.5;}
.options{display:flex;flex-direction:column;gap:7px;}
.opt-btn{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:9px 14px;text-align:left;color:var(--text);font-size:13px;font-family:var(--sans);cursor:pointer;transition:all .12s;display:flex;align-items:center;gap:9px;}
.opt-btn:hover:not([disabled]){border-color:var(--accent);background:rgba(124,106,255,.07);}
.opt-letter{font-family:var(--mono);font-size:10px;color:var(--muted);min-width:16px;font-weight:700;flex-shrink:0;}
.opt-btn.correct{border-color:var(--correct);background:rgba(61,232,176,.07);}
.opt-btn.correct .opt-letter{color:var(--correct);}
.opt-btn.wrong{border-color:var(--wrong);background:rgba(255,106,138,.07);}
.opt-btn.wrong .opt-letter{color:var(--wrong);}
.feedback{display:none;margin-top:9px;padding:9px 13px;border-radius:8px;font-size:12px;line-height:1.55;}
.feedback.show{display:block;}
.feedback.ok{background:rgba(61,232,176,.07);border-left:3px solid var(--correct);color:#8fffd8;}
.feedback.no{background:rgba(255,106,138,.07);border-left:3px solid var(--wrong);color:#ffb0c0;}

/* SCORE */
.score-corner{position:fixed;top:0;right:0;background:var(--card);border-left:1px solid var(--border);border-bottom:1px solid var(--border);border-radius:0 0 0 10px;padding:7px 14px;font-family:var(--mono);font-size:11px;color:var(--accent3);z-index:300;}

/* PROGRESS */
.page-progress{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:11px 16px;margin-bottom:22px;}
.prog-bar-outer{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.prog-bar-inner{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent3));border-radius:3px;transition:width .4s;width:0%;}
.prog-label{font-family:var(--mono);font-size:11px;color:var(--muted);white-space:nowrap;}

/* SECTION DIVIDER */
.section-divider{font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--accent4);margin:22px 0 10px;padding-bottom:6px;border-bottom:1px solid var(--border);}

strong{color:var(--text);}
code{font-family:var(--mono);background:var(--code-bg);padding:1px 5px;border-radius:4px;font-size:11px;color:var(--accent3);}
em{color:var(--accent4);font-style:normal;}
</style>
</head>
