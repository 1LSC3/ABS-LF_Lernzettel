<div class="page" id="page-fmea">
  <div class="page-hero" style="--glow:rgba(255,106,138,.15);">
    <div class="hero-label">Thema 6 · LF7</div>
    <div class="hero-title">⚠️ <span>FMEA</span></div>
    <div class="hero-sub">Strukturanalyse · Funktionsanalyse · RPZ · Risikobewertung · Maßnahmen</div>
  </div>
  <div class="content">

    <div class="card">
      <h3>Was ist FMEA? – Grundbegriff</h3>
      <p><strong>Failure Mode and Effects Analysis</strong> (Fehlermöglichkeits- und Einflussanalyse) ist eine systematische Methode zur <strong>präventiven Qualitätssicherung</strong>. Sie wurde ursprünglich in der Raumfahrt (NASA, 1960er) entwickelt und ist heute Pflichtbestandteil in sicherheitskritischen Branchen wie Automobilbau (IATF 16949), Medizintechnik und – zunehmend – in der CPS-Entwicklung.</p>
      <div class="hb hb-pink" style="margin-top:12px;">
        <strong>Grundgedanke:</strong> Mögliche Fehler <em>bevor</em> sie auftreten identifizieren, bewerten und durch gezielte Maßnahmen verhindern oder abschwächen. FMEA ist präventiv, nicht reaktiv.
      </div>
    </div>

    <div class="section-divider">Die 5 Schritte der FMEA</div>

    <div class="card">
      <h3>FMEA-Prozess</h3>
      <div class="steps">
        <div class="step"><div class="step-num">1</div><div class="step-body"><strong>Strukturanalyse:</strong> Das System hierarchisch in Baugruppen, Komponenten und Merkmale zerlegen. Schafft die Grundlage für alle weiteren Schritte.</div></div>
        <div class="step"><div class="step-num">2</div><div class="step-body"><strong>Funktionsanalyse:</strong> Welche Funktion hat jede Komponente? Was ist die erwartete Leistung? Basis für die Fehlerdefinition.</div></div>
        <div class="step"><div class="step-num">3</div><div class="step-body"><strong>Fehleranalyse:</strong> Für jede Funktion: Welche Fehler können auftreten? Welche Auswirkungen haben sie? Was sind die Ursachen?</div></div>
        <div class="step"><div class="step-num">4</div><div class="step-body"><strong>Risikobewertung (RPZ):</strong> Jeden Fehler mit B, A, E bewerten → RPZ berechnen → Prioritäten setzen.</div></div>
        <div class="step"><div class="step-num">5</div><div class="step-body"><strong>Maßnahmen &amp; Optimierung:</strong> Für Fehler mit hoher RPZ: Maßnahmen definieren, umsetzen, neue RPZ berechnen und prüfen ob verbessert.</div></div>
      </div>
    </div>

    <div class="section-divider">Strukturanalyse – Beispiel Wetterstation</div>

    <div class="card">
      <h3>Hierarchische Systemzerlegung</h3>
      <p style="margin-bottom:14px;font-size:13px;">Die Strukturanalyse zerlegt das System von oben nach unten. Jede Ebene beschreibt einen konkreteren Teil des Systems:</p>
      <div class="code-block" style="line-height:2.1;">
        <div style="color:var(--muted);font-size:11px;margin-bottom:8px;">Ebene 1: Gesamtsystem → Ebene 2: Baugruppe → Ebene 3: Komponente</div>
        <div style="color:var(--accent);font-weight:700;">CPS – Wetterstation</div>
        <div style="padding-left:20px;color:var(--accent3);">├── Gehäuse und Energieversorgung</div>
        <div style="padding-left:40px;color:#b0b4cc;">│&nbsp;&nbsp;&nbsp;└── 5V Spannungsversorgung</div>
        <div style="padding-left:20px;color:var(--accent3);">└── Sensoreinheiten</div>
        <div style="padding-left:40px;color:#b0b4cc;">&nbsp;&nbsp;&nbsp;&nbsp;├── Sensor Temperatur</div>
        <div style="padding-left:40px;color:#b0b4cc;">&nbsp;&nbsp;&nbsp;&nbsp;└── Sensor Luftfeuchte</div>
      </div>
      <p style="margin-top:12px;font-size:12px;color:var(--muted);">Die Strukturanalyse stellt sicher, dass kein Bestandteil vergessen wird. Erst wenn sie vollständig ist, kann die Fehleranalyse beginnen.</p>
    </div>

    <div class="section-divider">RPZ – Risikoprioritätszahl</div>

    <div class="card">
      <h3>Die drei Bewertungsfaktoren</h3>
      <div class="rpz-box" style="margin-bottom:14px;">
        <div style="color:var(--muted);font-size:12px;">Formel:</div>
        <div class="rpz-formula">RPZ = B × A × E</div>
        <div class="rpz-legend">
          <span><strong style="color:var(--accent2);">B</strong> = Bedeutung (Schwere der Fehlerfolge)</span>
          <span><strong style="color:var(--accent4);">A</strong> = Auftreten (Wahrscheinlichkeit des Fehlers)</span>
          <span><strong style="color:var(--accent3);">E</strong> = Entdeckung (Nicht-Entdeckbarkeit)</span>
        </div>
      </div>
      <table class="styled-table">
        <thead><tr><th>Faktor</th><th>Skala</th><th>Wert 1 = gut</th><th>Wert 10 = schlecht</th></tr></thead>
        <tbody>
          <tr><td><strong style="color:var(--accent2);">B – Bedeutung</strong></td><td>1–10</td><td>Keine Auswirkung auf Produkt/Nutzer</td><td>Gefährdung ohne Vorwarnung, sicherheitskritisch</td></tr>
          <tr><td><strong style="color:var(--accent4);">A – Auftreten</strong></td><td>1–10</td><td>Sehr unwahrscheinlich (&lt;1:1.000.000)</td><td>Fast unvermeidlich (&gt;1:2)</td></tr>
          <tr><td><strong style="color:var(--accent3);">E – Entdeckung ⚠️</strong></td><td>1–10</td><td>Wird mit Sicherheit vor Auslieferung erkannt</td><td>Keine Prüfmethode vorhanden, wird nicht erkannt</td></tr>
        </tbody>
      </table>
      <div class="hb hb-pink" style="margin-top:12px;">
        <strong>⚠️ Achtung E-Faktor:</strong> Bei E ist ein <em>hoher Wert schlecht</em>! E=10 bedeutet, der Fehler wird mit hoher Wahrscheinlichkeit <em>nicht</em> entdeckt. E=1 bedeutet, er wird sicher entdeckt.
      </div>
    </div>

    <div class="card">
      <h3>RPZ-Interpretation und Handlungsdruck</h3>
      <table class="styled-table">
        <thead><tr><th>RPZ-Bereich</th><th>Bewertung</th><th>Empfohlene Reaktion</th></tr></thead>
        <tbody>
          <tr><td style="color:var(--accent3);">1 – 50</td><td>Gering</td><td>Kein unmittelbarer Handlungsbedarf. Dokumentieren und beobachten.</td></tr>
          <tr><td style="color:var(--accent4);">51 – 100</td><td>Mittel</td><td>Maßnahmen prüfen, bei nächster Gelegenheit optimieren.</td></tr>
          <tr><td style="color:var(--accent2);">101 – 200</td><td>Erhöht</td><td>Handlungsbedarf. Maßnahmen zeitnah einleiten und RPZ neu berechnen.</td></tr>
          <tr><td style="color:var(--wrong);">201 – 1000</td><td>Kritisch</td><td>Sofortiger Handlungsbedarf. Produkt darf so nicht ausgeliefert werden.</td></tr>
        </tbody>
      </table>
      <div class="hb hb-orange" style="margin-top:12px;">
        <strong>Klausurbeispiel – Kabelbruch: B=6, A=5, E=4</strong><br>
        RPZ = 6 × 5 × 4 = <strong>120</strong> → Bereich „Erhöht" (101–200).<br>
        → <strong>Handlungsbedarf</strong>: Maßnahmen zeitnah einleiten, z.B. robustere Kabelführung, Schutzmantel, kürzere Inspektionsintervalle, Überströmschutz. Nach Umsetzung: neue RPZ berechnen.
      </div>
    </div>

    <div class="section-divider">Maßnahmen zur RPZ-Senkung</div>

    <div class="three-col">
      <div class="def-card">
        <div class="tag" style="background:rgba(255,106,138,.15);color:var(--accent2);">B senken</div>
        <p>Fehlerfolgen abschwächen: redundante Systeme, Sicherheitsmechanismen, Fail-Safe-Design (System geht bei Fehler in sicheren Zustand).</p>
      </div>
      <div class="def-card">
        <div class="tag" style="background:rgba(255,179,71,.15);color:var(--accent4);">A senken</div>
        <p>Fehlerursachen reduzieren: bessere Qualität der Bauteile, robusteres Design, bessere Fertigungsprozesse.</p>
      </div>
      <div class="def-card">
        <div class="tag" style="background:rgba(61,232,176,.15);color:var(--accent3);">E senken</div>
        <p>Entdeckungswahrscheinlichkeit erhöhen: mehr Tests, Sensoren, Diagnosesysteme, regelmäßige Inspektionen.</p>
      </div>
    </div>

    <!-- QUIZ FMEA -->
    <div class="quiz-block">
      <div class="quiz-label">Quiz · FMEA</div>
      <div class="page-progress">
        <div class="prog-bar-outer"><div class="prog-bar-inner" id="prog-fmea"></div></div>
        <div class="prog-label" id="plbl-fmea">0 / 5</div>
      </div>

      <div class="q-item">
        <div class="q-num">F 26</div>
        <div class="q-text">Was ist das Ziel der <strong>Strukturanalyse</strong> im FMEA-Prozess?</div>
        <div class="options">
          <button class="opt-btn" onclick="ans(this,'fmea',false,'Das ist das Ziel der Risikobewertung (RPZ), nicht der Strukturanalyse.')"><span class="opt-letter">A</span>Jedem Fehler eine Risikoprioritätszahl zuweisen</button>
          <button class="opt-btn" onclick="ans(this,'fmea',true,'Richtig! Die Strukturanalyse zerlegt das System hierarchisch in Baugruppen und Komponenten – sie ist die Grundlage für alle weiteren FMEA-Schritte.')"><span class="opt-letter">B</span>Das System hierarchisch in Baugruppen und Komponenten zerlegen</button>
          <button class="opt-btn" onclick="ans(this,'fmea',false,'Maßnahmen werden erst nach der Risikobewertung im 5. Schritt definiert.')"><span class="opt-letter">C</span>Maßnahmen zur Fehlerreduzierung festlegen</button>
        </div>
        <div class="feedback"></div>
      </div>

      <div class="q-item">
        <div class="q-num">F 27</div>
        <div class="q-text">Ein Sensor hat folgende Bewertung: B=4, A=7, E=6. Berechne die RPZ und bestimme den Handlungsbedarf.</div>
        <div class="options">
          <button class="opt-btn" onclick="ans(this,'fmea',false,'4+7+6=17 – das wäre Addition. RPZ wird durch Multiplikation berechnet.')"><span class="opt-letter">A</span>RPZ=17, kein Handlungsbedarf</button>
          <button class="opt-btn" onclick="ans(this,'fmea',false,'4×7=28, ×6=168 – nicht 112. Nochmal nachrechnen.')"><span class="opt-letter">B</span>RPZ=112, erhöhter Handlungsbedarf</button>
          <button class="opt-btn" onclick="ans(this,'fmea',true,'Richtig! RPZ = 4×7×6 = 168. Das liegt im erhöhten Bereich (101–200) → Maßnahmen zeitnah einleiten.')"><span class="opt-letter">C</span>RPZ=168, erhöhter Handlungsbedarf – Maßnahmen einleiten</button>
          <button class="opt-btn" onclick="ans(this,'fmea',false,'4×7×6=168, nicht 336.')"><span class="opt-letter">D</span>RPZ=336, sofortiger Handlungsbedarf</button>
        </div>
        <div class="feedback"></div>
      </div>

      <div class="q-item">
        <div class="q-num">F 28</div>
        <div class="q-text">Was bedeutet ein <strong>hoher E-Wert</strong> (z.B. E=9) in der FMEA – und warum ist das problematisch?</div>
        <div class="options">
          <button class="opt-btn" onclick="ans(this,'fmea',false,'Das ist das Gegenteil: Hoher E-Wert = Fehler wird kaum erkannt.')"><span class="opt-letter">A</span>Der Fehler wird mit hoher Wahrscheinlichkeit vor der Auslieferung entdeckt → gut.</button>
          <button class="opt-btn" onclick="ans(this,'fmea',true,'Richtig! Hoher E-Wert = Fehler wird kaum/nicht entdeckt. Das ist besonders gefährlich, da der Fehler unbemerkt bis zum Kunden gelangt und die RPZ stark erhöht.')"><span class="opt-letter">B</span>Der Fehler wird kaum entdeckt → gefährlich, weil er unbemerkt zum Kunden gelangt.</button>
          <button class="opt-btn" onclick="ans(this,'fmea',false,'E bewertet Entdeckbarkeit, nicht Häufigkeit. Häufigkeit wäre der A-Wert.')"><span class="opt-letter">C</span>Der Fehler tritt sehr häufig auf → hohe Wartungskosten.</button>
        </div>
        <div class="feedback"></div>
      </div>

      <div class="q-item">
        <div class="q-num">F 29</div>
        <div class="q-text">Worunter wird „Sensor Luftfeuchte" in der Strukturanalyse der CPS-Wetterstation eingeordnet?</div>
        <div class="options">
          <button class="opt-btn" onclick="ans(this,'fmea',false,'Gehäuse und Energieversorgung enthält die 5V Spannungsversorgung – keine Sensoren.')"><span class="opt-letter">A</span>Gehäuse und Energieversorgung</button>
          <button class="opt-btn" onclick="ans(this,'fmea',true,'Richtig! Sensoreinheiten ist die Baugruppe, die sowohl Sensor Temperatur als auch Sensor Luftfeuchte enthält.')"><span class="opt-letter">B</span>Sensoreinheiten</button>
          <button class="opt-btn" onclick="ans(this,'fmea',false,'CPS-Wetterstation ist die oberste Ebene (Gesamtsystem). Sensoren sind tiefer in der Hierarchie.')"><span class="opt-letter">C</span>CPS – Wetterstation (direkt, ohne Zwischenebene)</button>
        </div>
        <div class="feedback"></div>
      </div>

      <div class="q-item">
        <div class="q-num">F 30</div>
        <div class="q-text">Ein Fehler hat RPZ=250. Welche Maßnahme senkt die RPZ am stärksten, wenn der <strong>B-Wert von 10 auf 2</strong> reduziert werden kann (A=5, E=5 bleiben)?</div>
        <div class="options">
          <button class="opt-btn" onclick="ans(this,'fmea',false,'Neue RPZ = 2×5×5 = 50. Das ist eine drastische Verbesserung. Die Antwort stimmt in der Richtung, aber die RPZ-Berechnung ist falsch.')"><span class="opt-letter">A</span>Neue RPZ = 100 → mittlerer Bereich, weiterhin Handlungsbedarf</button>
          <button class="opt-btn" onclick="ans(this,'fmea',true,'Richtig! Neue RPZ = 2×5×5 = 50 → geringer Bereich. Die drastische Senkung des B-Werts (Fehlerfolge abschwächen) ist oft die wirkungsvollste Maßnahme.')"><span class="opt-letter">B</span>Neue RPZ = 50 → geringer Bereich, kein unmittelbarer Handlungsbedarf mehr</button>
          <button class="opt-btn" onclick="ans(this,'fmea',false,'2×5×5=50, nicht 200.')"><span class="opt-letter">C</span>Neue RPZ = 200 → immer noch erhöhter Bereich</button>
        </div>
        <div class="feedback"></div>
      </div>
    </div>
  </div>
</div>

<script>
const PAGE_IDS = ['home','prototypen','git','requirements','arduino','devops','fmea'];
const PAGE_TOTAL = { prototypen:5, git:5, requirements:5, arduino:5, devops:5, fmea:5 };
const state = {};
PAGE_IDS.filter(p=>p!=='home').forEach(p=>{ state[p]={answered:0,correct:0}; });
let gCorrect=0, gAnswered=0;

function goTo(pageId){
  PAGE_IDS.forEach(id=>{ document.getElementById('page-'+id).classList.remove('active'); });
  document.getElementById('page-'+pageId).classList.add('active');
  document.querySelectorAll('.tab').forEach(t=>{ t.classList.toggle('active', t.dataset.page===pageId); });
  window.scrollTo({top:0,behavior:'smooth'});
}

document.querySelectorAll('.tab').forEach(tab=>{
  tab.addEventListener('click', function(){ goTo(this.dataset.page); });
});

function ans(btn, page, isCorrect, explanation){
  const item = btn.closest('.q-item');
  if(item.dataset.done) return;
  item.dataset.done='1';
  item.querySelectorAll('.opt-btn').forEach(b=>{ b.disabled=true; });
  const fb = item.querySelector('.feedback');
  if(isCorrect){
    btn.classList.add('correct');
    fb.className='feedback ok show';
    fb.textContent='✓ Richtig! '+explanation;
    state[page].correct++;
    gCorrect++;
  } else {
    btn.classList.add('wrong');
    fb.className='feedback no show';
    fb.textContent='✗ Leider falsch. '+explanation;
    item.querySelectorAll('.opt-btn').forEach(b=>{
      const oc=b.getAttribute('onclick')||'';
      if(oc.includes("ans(this,'"+page+"',true")){ b.classList.add('correct'); }
    });
  }
  state[page].answered++;
  gAnswered++;
  refreshProgress(page);
  refreshScore();
  refreshHomeCards();
}

function refreshProgress(page){
  const total=PAGE_TOTAL[page], done=state[page].answered;
  const bar=document.getElementById('prog-'+page);
  const lbl=document.getElementById('plbl-'+page);
  if(bar) bar.style.width=((done/total)*100)+'%';
  if(lbl) lbl.textContent=done+' / '+total;
}

function refreshScore(){
  document.getElementById('score-disp').textContent=gCorrect+'/'+gAnswered;
}

function refreshHomeCards(){
  Object.keys(state).forEach(page=>{
    const el=document.getElementById('hs-'+page);
    if(!el) return;
    const total=PAGE_TOTAL[page], done=state[page].answered, cor=state[page].correct;
    if(done===0){ el.textContent=total+' Fragen'; el.style.color=''; }
    else if(done<total){ el.textContent=done+'/'+total+' · '+cor+' richtig'; el.style.color=''; }
    else { el.textContent='✓ Fertig · '+cor+'/'+total+' richtig'; el.style.color=cor===total?'var(--correct)':'var(--accent4)'; }
  });
}
</script>
</body>
</html>
